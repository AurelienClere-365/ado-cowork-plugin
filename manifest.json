{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.28/MicrosoftTeams.schema.json",
  "manifestVersion": "1.28",
  "version": "1.0.0",
  "id": "e8b2a3f1-7c4d-4f91-b2e0-ad01c0ca0001",
  "developer": {
    "name": "Aurelien Clere",
    "websiteUrl": "https://github.com/AurelienClere-365/ado-cowork-plugin",
    "privacyUrl": "https://github.com/AurelienClere-365/ado-cowork-plugin/blob/main/PRIVACY.md",
    "termsOfUseUrl": "https://github.com/AurelienClere-365/ado-cowork-plugin/blob/main/LICENSE"
  },
  "name": {
    "short": "ADO Cowork",
    "full": "Azure DevOps Cowork Plugin"
  },
  "description": {
    "short": "Azure DevOps AI assistant for Project Managers — and your whole team.",
    "full": "Designed for Project Managers who need live Azure DevOps data without leaving their AI assistant: sprint health reports, go/no-go readiness checklists, velocity trends, stakeholder updates, backlog grooming, and committee-ready PowerPoint decks grounded in real ADO data. Developers and functional consultants benefit too: query work items, monitor pipelines, review pull requests, browse repositories, manage test plans, and write wiki pages — all through natural language."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078d4",
  "agentSkills": [
    {"folder": "./skills/ado-context"},
    {"folder": "./skills/ado-pm-reporting"},
    {"folder": "./skills/ado-project-discovery"},
    {"folder": "./skills/ado-work-items"},
    {"folder": "./skills/ado-sprints-capacity"},
    {"folder": "./skills/ado-pipelines"},
    {"folder": "./skills/ado-repositories"},
    {"folder": "./skills/ado-pull-requests"},
    {"folder": "./skills/ado-test-plans"},
    {"folder": "./skills/ado-search"},
    {"folder": "./skills/ado-wiki"}
  ],
  "agentConnectors": [
    {
      "id": "ado-mcp-connector",
      "displayName": "Azure DevOps MCP",
      "description": "Remote MCP connector to the Microsoft Azure DevOps MCP server.",
      "toolSource": {
        "remoteMcpServer": {
          "mcpServerUrl": "https://mcp.dev.azure.com/contoso",
          "mcpToolDescription": {
            "file": "ado-mcp-tools.json"
          },
          "authorization": {
            "type": "None"
          }
        }
      }
    }
  ],
  "permissions": [],
  "validDomains": []
}
